    {
      "id": "consistency_score",
      "formula": "streak_days + sessions_completed + on_time_assignments"
    },
    {
      "id": "mastery_score",
      "formula": "mastery_upgrades + strong_lines + strong_skill_buckets"
    }
  ],
  "recommended_defaults": {
