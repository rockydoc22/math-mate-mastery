{
  "mistake_coach": {
    "enabled": true,
    "mode": "post_answer_feedback",
    "merge_if_exists": true,
    "coach_tone": [
      "encouraging",
      "brief",
      "specific",
      "non-shaming"
    ],
    "detection_dimensions": [
      "concept_error",
      "procedure_error",
      "careless_error",
      "reading_misread",
      "time_pressure_guess"
    ],
    "subjects": {
      "Math": {
        "patterns": [
          {
            "id": "sign_error",
            "signals": [
              "negative/positive confusion",
              "incorrect subtraction",
              "distribution sign miss"
            ],
            "feedback": "Check the signs when combining or distributing terms.",
            "follow_up_skill": "algebra_signs"
          },
          {
            "id": "operation_swap",
            "signals": [
              "added instead of multiplied",
              "divided instead of subtracted"
            ],
            "feedback": "Pause and identify the operation the question is asking for before calculating.",
            "follow_up_skill": "operation_selection"
          },
          {
            "id": "slope_intercept_confusion",
            "signals": [
              "confuses slope with y-intercept"
            ],
            "feedback": "Slope tells how fast the line changes; intercept tells where it crosses the y-axis.",
            "follow_up_skill": "graphing_linear_equations"
          },
          {
            "id": "formula_selection",
            "signals": [
              "uses wrong geometry formula"
            ],
            "feedback": "Choose the formula that matches the shape before plugging in values.",
            "follow_up_skill": "geometry_formulas"
          }
        ]
      },
      "Reading": {
        "patterns": [
          {
            "id": "detail_vs_main_idea",
            "signals": [
              "chooses a small detail as main idea"
            ],
            "feedback": "Look for the sentence that captures the whole passage, not just one example.",
            "follow_up_skill": "main_idea"
          },
          {
            "id": "inference_without_evidence",
            "signals": [
              "makes assumption not supported by text"
            ],
            "feedback": "For inference questions, your choice should be supported by clues in the passage.",
            "follow_up_skill": "inference"
          },
          {
            "id": "tone_confusion",
            "signals": [
              "mistakes tone or attitude"
            ],
            "feedback": "Pay attention to descriptive word choice to identify tone.",
            "follow_up_skill": "author_tone"
          }
        ]
      },
      "Science": {
        "patterns": [
          {
            "id": "variable_confusion",
            "signals": [
              "independent/dependent variable mix-up"
            ],
            "feedback": "Ask what is being changed and what is being measured.",
            "follow_up_skill": "scientific_method"
          },
          {
            "id": "cause_effect_mixup",
            "signals": [
              "reverses causal relationship"
            ],
            "feedback": "Trace the process step by step to identify what causes what.",
            "follow_up_skill": "cause_effect"
          }
        ]
      },
      "Social Studies": {
        "patterns": [
          {
            "id": "chronology_error",
            "signals": [
              "events placed out of order"
            ],
            "feedback": "Anchor each event to a broader era before selecting the answer.",
            "follow_up_skill": "historical_timeline"
          },
          {
            "id": "branch_of_government_confusion",
            "signals": [
              "mixes roles of branches"
            ],
            "feedback": "Legislative makes laws, executive enforces, judicial interprets.",
            "follow_up_skill": "civics_branches"
          }
        ]
      },
      "Writing": {
        "patterns": [
          {
            "id": "grammar_vs_style",
            "signals": [
              "chooses stylistic option over grammatically correct one"
            ],
            "feedback": "First eliminate options with grammar errors; then choose the clearest style.",
            "follow_up_skill": "grammar_editing"
          },
          {
            "id": "transition_mismatch",
            "signals": [
              "uses transition that does not match relationship"
            ],
            "feedback": "Match the transition to the relationship: contrast, cause, sequence, or example.",
            "follow_up_skill": "transitions"
          }
        ]
      }
    },
    "response_template": {
      "headline": "What happened here?",
      "body": "It looks like {{pattern_feedback}}",
      "retry_prompt": "Try one more like this with a quick hint.",
      "confidence_prompt": "Want the short explanation or step-by-step help?"
    }
  }
}