{
  "timer_and_pacing": {
    "enabled": true,
    "modes": [
      "strict_exam_timer",
      "section_timer",
      "soft_timer_with_nudges"
    ],
    "nudges": [
      {
        "trigger": "25_percent_time_left",
        "message": "Keep moving. Flag anything that is slowing you down."
      },
      {
        "trigger": "10_percent_time_left",
        "message": "Final stretch. Prioritize questions you can finish quickly."
      },
      {
        "trigger": "pace_ahead",
        "message": "Nice pace. Use the extra time to check marked questions."
      }
    ],
    "anti_panic_rules": {
      "after_two_slow_questions": "offer_breathe_and_skip_nudge_if_coach_mode"
    }
  }
}